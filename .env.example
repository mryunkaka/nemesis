# Server Configuration
PORT=3000
CORS_ORIGIN=*

# Database Path (relative to project root)
SQLITE_PATH=data/dashboard.sqlite

# Dataset Directory
AUDIT_DATASET_DIR=dataset
LIVE_SYNC_DIR=data/live-sync

# GeoJSON Data Path
GEO_ROOT_PATH=seed/geo

# Auto refresh dataset + rebuild DB
# Set true to enable scheduler inside the Node process
AUTO_REFRESH_ENABLED=false

# Run one refresh right after server boot
AUTO_REFRESH_RUN_ON_STARTUP=false

# Daily schedule in local timezone below
AUTO_REFRESH_HOUR=1
AUTO_REFRESH_MINUTE=0
AUTO_REFRESH_TIMEZONE=Asia/Jakarta

# Refresh source:
# - none    : only rebuild from local dataset files
# - http    : download file(s) from URL(s) below into AUDIT_DATASET_DIR
# - command : run AUTO_REFRESH_COMMAND to fetch/update dataset externally
AUTO_REFRESH_SOURCE_MODE=none

# For http mode: comma or newline separated URLs.
# Supports {year} placeholder.
AUTO_REFRESH_SOURCE_URLS=

# Optional JSON headers for http mode, example:
# {"Authorization":"Bearer xxx","User-Agent":"nemesis-bot/1.0"}
AUTO_REFRESH_HEADERS_JSON=

# Optional: remove old year-{year}.part-*.csv/jsonl before moving new files
AUTO_REFRESH_CLEAN_DATASET_DIR=false

# Timeout for http download or command execution
AUTO_REFRESH_TIMEOUT_MS=300000

# For command mode: command must update files inside AUDIT_DATASET_DIR
AUTO_REFRESH_COMMAND=
AUTO_REFRESH_SYNC_CODES=

# Optional admin token for manual trigger/status API
AUTO_REFRESH_ADMIN_TOKEN=
AUTO_REFRESH_ALLOW_MANUAL_TRIGGER=true

# Browser mode for scripts/fetch-inaproc-package.js
INAPROC_BROWSER_MODE=real
INAPROC_BROWSER_USE_KERNEL=false
